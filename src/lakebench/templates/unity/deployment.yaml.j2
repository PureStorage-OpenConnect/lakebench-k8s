apiVersion: apps/v1
kind: Deployment
metadata:
  name: lakebench-unity
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/managed-by: lakebench
    app.kubernetes.io/component: unity-catalog
spec:
  replicas: 1
  selector:
    matchLabels:
      app: lakebench-unity
  template:
    metadata:
      labels:
        app: lakebench-unity
        app.kubernetes.io/component: unity-catalog
    spec:
      serviceAccountName: lakebench-spark-runner
      initContainers:
        - name: copy-config
          image: busybox:1.36
          command: ["sh", "-c"]
          args:
            - |
              cp /config-src/* /config-dst/
          volumeMounts:
            - name: config-src
              mountPath: /config-src
            - name: config
              mountPath: /config-dst
      containers:
        - name: unity
          image: {{ unity_image }}
          ports:
            - containerPort: {{ unity_port }}
          resources:
            requests:
              cpu: {{ unity_cpu }}
              memory: {{ unity_memory }}
            limits:
              cpu: {{ unity_cpu }}
              memory: {{ unity_memory }}
          volumeMounts:
            - name: config
              mountPath: /home/unitycatalog/etc/conf
          readinessProbe:
            httpGet:
              path: /api/2.1/unity-catalog/catalogs
              port: {{ unity_port }}
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 6
          startupProbe:
            httpGet:
              path: /api/2.1/unity-catalog/catalogs
              port: {{ unity_port }}
            initialDelaySeconds: 10
            periodSeconds: 5
            failureThreshold: 30
      volumes:
        - name: config-src
          configMap:
            name: lakebench-unity
        - name: config
          emptyDir: {}
