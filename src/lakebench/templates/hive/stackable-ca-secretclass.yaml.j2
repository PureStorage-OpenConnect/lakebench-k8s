---
# Stackable SecretClass for S3 CA Certificate
# Allows Stackable operators to find CA cert from labeled secrets
apiVersion: secrets.stackable.tech/v1alpha1
kind: SecretClass
metadata:
  name: lakebench-s3-ca-cert-class
  namespace: {{ namespace }}
  labels:
    app.kubernetes.io/name: lakebench
    app.kubernetes.io/instance: {{ name }}
    app.kubernetes.io/component: s3
    app.kubernetes.io/managed-by: lakebench
spec:
  backend:
    k8sSearch:
      searchNamespace:
        pod: {}
